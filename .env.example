# Telegram Bot Token
# 從 @BotFather 取得
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key
# 從 https://platform.openai.com/ 取得
OPENAI_API_KEY=your_openai_api_key_here

# Weather API Key (OpenWeatherMap)
# 從 https://openweathermap.org/api 取得 (免費)
WEATHER_API_KEY=your_weather_api_key_here

# 資料庫路徑
# 本地開發可用 sqlite:///data/assistant.db
# Zeabur 正式建議使用 PostgreSQL 連線字串
# 例: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///data/assistant.db
DB_AUTO_MIGRATE=true
DB_ECHO=false

# 時區設定
TIMEZONE=Asia/Taipei

# OpenAI 模型設定
OPENAI_MODEL=gpt-4o-mini

# 助手人設提示詞 (可選)
# 預設為「貼心女友 + 能幹助手」；可在 Zeabur 直接覆蓋
ASSISTANT_PERSONA_PROMPT=你是一位貼心的女友角色，同時也是能幹的生活與工作助手。請使用繁體中文回覆，語氣溫柔且專業。

# 記帳提醒時間 (24小時制)
DAILY_REMINDER_HOUR=20
DAILY_REMINDER_MINUTE=0

# 月報提醒日期
MONTHLY_REPORT_DAY=1
